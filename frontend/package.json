{
  "name": "oak",
  "type": "module",
  "version": "1.7.7",
  "description": "Oak front-end",
  "main": "index.js",
  "scripts": {
    "build": "vite build",
    "server": "vite dev --host 0.0.0.0 --port 8080",
    "test": "NODE_OPTIONS='--loader ./spec/support/jsx-loader.mjs' nyc npx jasmine spec/**/*.js",
    "coverage": "NODE_OPTIONS='--loader ./spec/support/jsx-loader.mjs' npx c8 --reporter=lcov jasmine spec/**/*.js",
    "lint": "eslint assets spec",
    "lint_fix": "eslint assets spec --fix"
  },
  "author": "darthjee",
  "license": "MIT",
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@tanstack/react-query": "^5.62.23",
    "bootstrap": "^5.3.0",
    "react": "^19.2.0",
    "react-bootstrap": "2.10.10",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-complexity": "^1.0.2",
    "eslint-plugin-jasmine": "^4.1.3",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jasmine": "^5.0.0",
    "c8": "11.0.0",
    "nyc": "^15.0.0",
    "sass": "^1.69.0",
    "vite": "^7.3.2"
  },
  "jasmine": {
    "spec_dir": "spec",
    "spec_files": [
      "**/*[sS]pec.js"
    ]
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "extension": [
      ".js",
      ".jsx"
    ],
    "include": [
      "assets/js/**/*.js",
      "assets/js/**/*.jsx"
    ],
    "exclude": [
      "spec/**",
      "coverage/**"
    ],
    "all": true,
    "check-coverage": false
  }
}
